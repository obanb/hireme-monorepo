{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/reception/registration-cards/[id]",
      "regex": "^/reception/registration\\-cards/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/reception/registration\\-cards/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/reception/reservation-checks/[originId]",
      "regex": "^/reception/reservation\\-checks/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPoriginId": "nxtPoriginId"
      },
      "namedRegex": "^/reception/reservation\\-checks/(?<nxtPoriginId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/reception",
      "regex": "^/reception(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reception(?:/)?$"
    },
    {
      "page": "/reception/arriving-guests",
      "regex": "^/reception/arriving\\-guests(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reception/arriving\\-guests(?:/)?$"
    },
    {
      "page": "/reception/arriving-guests/calendar",
      "regex": "^/reception/arriving\\-guests/calendar(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reception/arriving\\-guests/calendar(?:/)?$"
    },
    {
      "page": "/reception/registration-cards",
      "regex": "^/reception/registration\\-cards(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reception/registration\\-cards(?:/)?$"
    },
    {
      "page": "/reception/reservation-checks",
      "regex": "^/reception/reservation\\-checks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reception/reservation\\-checks(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}